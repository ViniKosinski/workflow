generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE   @map("active")
  DISABLED @map("disabled")

  @@map("user_status")
}

model User {
  id              String         @id @db.VarChar(64)
  email           String         @db.VarChar(320)
  normalizedEmail String         @unique @map("normalized_email") @db.VarChar(320)
  name            String         @db.VarChar(160)
  status          UserStatus     @default(ACTIVE)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  credential      UserCredential?
  sessions        AuthSession[]
  workflows       WorkflowDefinition[]

  @@map("users")
}

model UserCredential {
  userId            String   @id @map("user_id") @db.VarChar(64)
  passwordHash      String   @map("password_hash") @db.Text
  passwordChangedAt DateTime @default(now()) @map("password_changed_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credentials")
}

model AuthSession {
  id         String    @id @db.VarChar(64)
  userId     String    @map("user_id") @db.VarChar(64)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  userAgent  String?   @map("user_agent") @db.VarChar(512)
  ipAddress  String?   @map("ip_address") @db.VarChar(64)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AuthRateLimitBucket {
  key             String   @id @db.VarChar(64)
  attemptCount    Int      @map("attempt_count")
  windowExpiresAt DateTime @map("window_expires_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([windowExpiresAt])
  @@map("auth_rate_limit_buckets")
}

enum WorkflowStatus {
  DRAFT     @map("draft")
  READY     @map("ready")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")
  CANCELLED @map("cancelled")

  @@map("workflow_status")
}

enum WorkflowStepStatus {
  PENDING   @map("pending")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")

  @@map("workflow_step_status")
}

enum WorkflowEventScope {
  WORKFLOW @map("workflow")
  STEP     @map("step")

  @@map("workflow_event_scope")
}

model WorkflowDefinition {
  id          String    @id @db.VarChar(64)
  ownerUserId String    @map("owner_user_id") @db.VarChar(64)
  name        String    @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt  DateTime? @map("archived_at") @db.Timestamptz(6)

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  steps WorkflowDefinitionStep[]
  runs  WorkflowRun[]

  @@index([ownerUserId, createdAt])
  @@map("workflow_definitions")
}

model WorkflowDefinitionStep {
  id                   String             @id @db.VarChar(64)
  workflowDefinitionId String             @map("workflow_definition_id") @db.VarChar(64)
  name                 String             @db.VarChar(255)
  order                Int
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  runSteps             WorkflowRunStep[]

  @@unique([workflowDefinitionId, order])
  @@index([workflowDefinitionId])
  @@map("workflow_definition_steps")
}

model WorkflowRun {
  id                   String         @id @db.VarChar(64)
  workflowDefinitionId String         @map("workflow_definition_id") @db.VarChar(64)
  status               WorkflowStatus
  currentStepId        String?        @unique @map("current_step_id") @db.VarChar(64)
  startedAt            DateTime?      @map("started_at") @db.Timestamptz(6)
  finishedAt           DateTime?      @map("finished_at") @db.Timestamptz(6)
  failureReason        String?        @map("failure_reason") @db.Text
  cancellationReason   String?        @map("cancellation_reason") @db.Text
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  workflowDefinition WorkflowDefinition       @relation(fields: [workflowDefinitionId], references: [id], onDelete: Restrict)
  currentStep        WorkflowRunStep?         @relation("CurrentWorkflowRunStep", fields: [currentStepId], references: [id], onDelete: SetNull)
  steps              WorkflowRunStep[]        @relation("WorkflowRunSteps")
  events             WorkflowExecutionEvent[]

  @@index([workflowDefinitionId])
  @@index([workflowDefinitionId, createdAt])
  @@index([status])
  @@map("workflow_runs")
}

model WorkflowRunStep {
  id                       String             @id @db.VarChar(64)
  workflowRunId            String             @map("workflow_run_id") @db.VarChar(64)
  workflowDefinitionStepId String?            @map("workflow_definition_step_id") @db.VarChar(64)
  name                     String             @db.VarChar(255)
  order                    Int
  status                   WorkflowStepStatus
  executionResult          Json?              @map("execution_result")
  startedAt                DateTime?          @map("started_at") @db.Timestamptz(6)
  finishedAt               DateTime?          @map("finished_at") @db.Timestamptz(6)
  errorMessage             String?            @map("error_message") @db.Text
  createdAt                DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  workflowRun            WorkflowRun              @relation("WorkflowRunSteps", fields: [workflowRunId], references: [id], onDelete: Cascade)
  workflowDefinitionStep WorkflowDefinitionStep?   @relation(fields: [workflowDefinitionStepId], references: [id], onDelete: SetNull)
  currentForRun          WorkflowRun?              @relation("CurrentWorkflowRunStep")
  events                 WorkflowExecutionEvent[]

  @@unique([workflowRunId, order])
  @@index([workflowRunId])
  @@index([workflowDefinitionStepId])
  @@index([status])
  @@map("workflow_run_steps")
}

model WorkflowExecutionEvent {
  id                   String              @id @db.VarChar(64)
  workflowRunId        String              @map("workflow_run_id") @db.VarChar(64)
  workflowRunStepId    String?             @map("workflow_run_step_id") @db.VarChar(64)
  eventType            String              @map("event_type") @db.VarChar(80)
  eventScope           WorkflowEventScope  @map("event_scope")
  fromWorkflowStatus   WorkflowStatus?     @map("from_workflow_status")
  toWorkflowStatus     WorkflowStatus?     @map("to_workflow_status")
  fromStepStatus       WorkflowStepStatus? @map("from_step_status")
  toStepStatus         WorkflowStepStatus? @map("to_step_status")
  message              String              @db.Text
  metadata             Json?
  error                String?             @db.Text
  occurredAt           DateTime            @map("occurred_at") @db.Timestamptz(6)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  workflowRun     WorkflowRun      @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  workflowRunStep WorkflowRunStep? @relation(fields: [workflowRunStepId], references: [id], onDelete: SetNull)

  @@index([workflowRunId, occurredAt])
  @@index([workflowRunStepId])
  @@index([eventType])
  @@index([eventScope])
  @@map("workflow_execution_events")
}
